{
  "expo": {
    "name": "ChargeHub",
    "slug": "chargehub",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "chargehub",
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "ChargeHub uses your location to show nearby EV charging stations."
        }
      ]
    ],
    "ios": {
      "bundleIdentifier": "com.akbarbadsha.chargehub",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "ChargeHub uses your location to show nearby EV charging stations."
      },
      "supportsTablet": true
    },
    "android": {
      "package": "com.akbarbadsha.chargehub",
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "extra": {
      "eas": {
        "projectId": "140a68a0-fc6e-4147-bc3e-ec9648e8cfce"
      }
    },
    "owner": "akbarbadsha25"
  }
}
